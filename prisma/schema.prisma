generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum USER_ROLES {
  CLIENT
  ADMIN
  MODERATOR
}

enum USER_STATUS {
  ACTIVE
  INACTIVE
}

model User {
  id        String      @id @default(uuid())
  name      String
  email     String      @unique
  password  String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  role      USER_ROLES  @default(CLIENT)
  status    USER_STATUS @default(INACTIVE)

  sessions  Session[]

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@map("sessions")
}